# Production Environment Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# Application
APP_NAME=AI Bot Platform
APP_ENV=production
DEBUG=False
SECRET_KEY=change-this-to-a-random-secure-key-in-production
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================
# Database Configuration (Production)
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/aibot_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================
# Redis Configuration (Production)
# ============================================
REDIS_URL=redis://host:6379/0
REDIS_TTL=3600
REDIS_ENABLED=True

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================
# PRIMARY: Google AI Studio Configuration
# ============================================
GOOGLE_API_KEY=your-production-google-api-key
GOOGLE_MODEL=gemini-1.5-pro

# ============================================
# TELEGRAM Configuration
# ============================================
TELEGRAM_BOT_TOKEN=your-production-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-production-domain.com/api/v1/telegram/webhook

# ============================================
# WHATSAPP Configuration
# ============================================
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_QR_TIMEOUT=120
WHATSAPP_QR_EXPIRY=300

# ============================================
# OpenAI Configuration (Optional)
# ============================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# Vector Database Configuration
# ============================================
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=aibot_knowledge
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# SMTP Configuration (for email notifications)
# ============================================
SMTP_HOST=your-smtp-server.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=AI Bot Platform
SMTP_FROM_EMAIL=noreply@aibot.com

# ============================================
# Monitoring and Logging
# ============================================
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn-for-error-tracking
PROMETHEUS_PORT=9090

# ============================================
# Security Settings
# ============================================
CORS_ORIGINS=["https://your-frontend-domain.com", "https://your-dashboard-domain.com"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ============================================
# Features
# ============================================
ENABLE_VOICE_SUPPORT=True
ENABLE_FILE_UPLOAD=True
ENABLE_WORKFLOW_AUTOMATION=True
ENABLE_LEARNING_SYSTEM=True
MAX_FILE_SIZE=10485760  # 10MB

# ============================================
# AWS Configuration (if using AWS services)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ============================================
# GCP Configuration (if using Google Cloud)
# ============================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_CREDENTIALS_JSON={"type": "service_account", ...}

# ============================================
# Ollama Configuration (if using local LLM)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat

# ============================================
# Twilio Configuration (Optional)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
