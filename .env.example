# Application
APP_NAME=AI Bot Platform
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aibot_db
DATABASE_ECHO=True
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================
# PRIMARY: Google AI Studio Configuration
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-1.5-pro

# ============================================
# TELEGRAM Configuration
# ============================================
# Create bot with @BotFather on Telegram
# Get token and add it below
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/v1/telegram/webhook

# ============================================
# WHATSAPP Configuration  
# ============================================
# Get from: https://developers.facebook.com/
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# OpenAI (Optional - falls back to Google AI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (local LLM - optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat

# Vector Database
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=aibot_knowledge
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Twilio (for WhatsApp alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=AI Bot Platform
SMTP_FROM_EMAIL=noreply@aibot.com

# Monitoring & Logging
LOG_LEVEL=INFO
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Security
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Features
ENABLE_VOICE_SUPPORT=True
ENABLE_FILE_UPLOAD=True
ENABLE_WORKFLOW_AUTOMATION=True
ENABLE_LEARNING_SYSTEM=True
MAX_FILE_SIZE=10485760  # 10MB

# Deployment
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_PROJECT_ID=
GCP_CREDENTIALS_JSON=

# Admin Panel
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

